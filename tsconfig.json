{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "ES2020",
    "target": "ES2020",

    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,

    "strict": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "rewriteRelativeImportExtensions": true,
    "verbatimModuleSyntax": false,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strictNullChecks": true
  }
}
